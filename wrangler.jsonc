{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hozumi-portfolio",
  "main": "./worker.js",
  "compatibility_date": "2026-07-13",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "hozumi-portfolio-media"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
